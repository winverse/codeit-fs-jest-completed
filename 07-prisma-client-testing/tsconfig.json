{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "jest"],
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "generated/**/*.ts",
    "prisma.config.ts"
  ]
}
